+#![forbid(unsafe_code)]
+
+use std::error::Error;
+use std::fmt::{self, Display, Formatter};
+use std::panic::Location;
+
+pub use error_union_derive::ErrorUnion;
+
+#[derive(Debug)]
+pub struct Located<E> {
+    source: E,
+    location: &'static Location<'static>,
+}
+
+impl<E> Located<E> {
+    #[track_caller]
+    pub fn new(source: E) -> Self {
+        Self {
+            source,
+            location: Location::caller(),
+        }
+    }
+
+    pub fn source_ref(&self) -> &E {
+        &self.source
+    }
+
+    pub fn into_source(self) -> E {
+        self.source
+    }
+
+    pub fn location(&self) -> &'static Location<'static> {
+        self.location
+    }
+}
+
+impl<E: Display> Display for Located<E> {
+    fn fmt(&self, f: &mut Formatter<'_>) -> fmt::Result {
+        write!(
+            f,
+            "{} (at {}:{}:{})",
+            self.source,
+            self.location.file(),
+            self.location.line(),
+            self.location.column()
+        )
+    }
+}
+
+impl<E: Error + 'static> Error for Located<E> {
+    fn source(&self) -> Option<&(dyn Error + 'static)> {
+        Some(&self.source)
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{ErrorUnion, Located};
+
+    #[derive(Debug, ErrorUnion)]
+    enum AppError {
+        Parse(Located<std::num::ParseIntError>),
+        Io(Located<std::io::Error>),
+    }
+
+    type Result<T> = std::result::Result<T, AppError>;
+
+    fn parse_num(s: &str) -> Result<u32> {
+        Ok(s.parse()?)
+    }
+
+    fn read_file(path: &str) -> Result<String> {
+        Ok(std::fs::read_to_string(path)?)
+    }
+
+    #[test]
+    fn use_case_parse_error_is_flat_and_located() {
+        let expected_line = line!() + 1;
+        let err = parse_num("abc").unwrap_err();
+
+        match err {
+            AppError::Parse(inner) => {
+                assert_eq!(inner.location().line(), expected_line);
+                assert_eq!(inner.source_ref().to_string(), "invalid digit found in string");
+            }
+            other => panic!("expected AppError::Parse(_), got {other:?}"),
+        }
+    }
+
+    #[test]
+    fn use_case_io_error_is_flat_and_located() {
+        let expected_line = line!() + 1;
+        let err = read_file("this-file-should-not-exist.txt").unwrap_err();
+
+        match err {
+            AppError::Io(inner) => {
+                assert_eq!(inner.location().line(), expected_line);
+                assert!(inner.source_ref().kind() == std::io::ErrorKind::NotFound);
+            }
+            other => panic!("expected AppError::Io(_), got {other:?}"),
+        }
+    }
+
+    #[test]
+    fn display_includes_source_and_location() {
+        let err = parse_num("abc").unwrap_err();
+        let rendered = err.to_string();
+
+        assert!(rendered.contains("invalid digit found in string"));
+        assert!(rendered.contains("error-union/src/lib.rs"));
+    }
+
+    #[test]
+    fn source_chain_exposes_located_wrapper() {
+        let err = parse_num("abc").unwrap_err();
+        assert!(std::error::Error::source(&err).is_some());
+    }
+}
